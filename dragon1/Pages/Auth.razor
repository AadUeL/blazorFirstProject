@page "/auth"
@using dragon1.ApiRequests
@using dragon1.ApiRequests.Models
@using dragon1.ApiRequests.Services
@inject UserService UserService

<PageTitle>Авторизация</PageTitle>

@if (UserService.CurrentUser == null)
{
    <h3>Вход в систему</h3>
    <hr />
    <div class="d-flex align-items-center">
        <form style="width:23rem;">
            <div class="mb-4">
                <label class="form-label">Login</label>
                <input type="text" @bind="_reqAuthUser.LoginName" class="form-control form-control-lg" />
            </div>
            <div class="mb-4">
                <label class="form-label">Password</label>
                <input type="password" @bind="_reqAuthUser.Password" class="form-control form-control-lg" />
            </div>
            <button type="button" @onclick="AuthLogin" class="btn btn-primary mb-4 w-100">Войти</button>

            <div class="d-flex align-items-center mt-3">
                <label class="me-2">Нет аккаунта?</label>
                <a href="/AddUser" class="btn btn-outline-secondary btn-sm">Зарегистрироваться</a>
            </div>
        </form>
    </div>
}
else
{
    <h3>Мой профиль</h3>
    <hr />

    <div style="width:23rem;">

        @if (isEditing)
        {
            <div class="mb-3">
                <label class="form-label">ФИО</label>
                <input type="text" @bind="editName" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">О себе</label>
                <input type="text" @bind="editDesc" class="form-control" />
            </div>

            <div class="d-grid gap-2">
                <button @onclick="SaveProfile" class="btn btn-success">Сохранить</button>
                <button @onclick="CancelEdit" class="btn btn-outline-secondary">Отмена</button>
            </div>
        }
        else
        {
            <p><strong>ID:</strong> @UserService.CurrentUser.idUser</p>
            <p><strong>ФИО:</strong> @UserService.CurrentUser.name</p>
            <p><strong>О себе:</strong> @UserService.CurrentUser.description</p>


            @if (UserService.CurrentUser.roleId == 2)
            {
                <p><strong>Роль: </strong>Обычный пользователь</p>
            }
            else
            {
                <p><strong>Роль: </strong>Администратор</p>
            }


            <div class="d-grid gap-2">
                <button @onclick="StartEdit" class="btn btn-primary">Редактировать профиль</button>
                <button @onclick="Logout" class="btn btn-outline-secondary">Выйти</button>
            </div>
        }

    </div>
}

@code {
    [Inject] private ApiRequest _apiRequest { get; set; }

    private ReqAuthUser _reqAuthUser = new ReqAuthUser();

    private bool isEditing = false;
    private string editName = "";
    private string editDesc = "";

    private async Task AuthLogin()
    {
        var reqAuthUserdata = await _apiRequest.GetUserFromApi(_reqAuthUser);

        if (reqAuthUserdata.status && reqAuthUserdata.user != null)
        {
            UserService.SetCurrentUser(reqAuthUserdata);
            StateHasChanged();
        }
    }

    private void Logout()
    {
        UserService.Logout();
        isEditing = false;
        StateHasChanged();
    }

    private void StartEdit()
    {
        if (UserService.CurrentUser != null)
        {
            editName = UserService.CurrentUser.name;
            editDesc = UserService.CurrentUser.description;
            isEditing = true;
            StateHasChanged();
        }
    }

    private void CancelEdit()
    {
        isEditing = false;
        StateHasChanged();
    }

    private async Task SaveProfile()
    {
        if (UserService.CurrentUser == null) return;

        var updateData = new ReqUpdateUser
        {
            Name = editName,
            Description = editDesc
        };


        var result = await _apiRequest.UpdateUser(UserService.CurrentUser.idUser, updateData);

        if (result.status)
        {
            UserService.CurrentUser.name = editName;
            UserService.CurrentUser.description = editDesc;

            isEditing = false;
        }
        else

        StateHasChanged();
    }
}