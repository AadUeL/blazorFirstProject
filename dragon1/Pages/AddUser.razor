@page "/AddUser"
@using dragon1.ApiRequests
@using dragon1.ApiRequests.Models
@using dragon1.ApiRequests.Services
@inject UserService UserService

<PageTitle>Регистрация пользователя</PageTitle>


<h3>Регистрация</h3>
<hr />
<div class="d-flex align-items-center p-4">
    <form style="width: 23rem;">
        <div class="form-outline mb-4">
            <label class="form-label">Name</label>
            <input type="text" @bind="@newUser.Name" class="form-control form-control-lg" />
        </div>
        <div class="form-outline mb-4">
            <label class="form-label">Description</label>
            <input type="text" @bind="@newUser.Description" class="form-control form-control-lg" />
        </div>
        <div class="form-outline mb-4">
            <label class="form-label">Login</label>
            <input type="text" @bind="@newUser.LoginName" class="form-control form-control-lg" />
        </div>
        <div class="form-outline mb-4">
            <label class="form-label">Password</label>
            <input type="password" @bind="@newUser.Password" class="form-control form-control-lg" />
        </div>
        <div class="pt-1 mb-4">
            <button class="btn btn-success w-100" @onclick="AddNewUser" type="button">Сохранить</button>
        </div>
        <div class="d-flex gap-2 mt-4">
            
            @if(UserService.CurrentUser == null)
            {
                <a href="/auth" class="btn btn-outline-secondary">К входу</a>
            }

            @if (UserService.CurrentUser != null && UserService.CurrentUser.roleId == 1)
            {
                <a href="/counter" class="btn btn-outline-secondary">К списку</a>
            }
        </div>
    </form>
</div>

@code {
    [Inject] private ApiRequest _apiRequest { get; set; }

    private ReqDataUser newUser = new ReqDataUser();


	private async Task AddNewUser()
	{
        var reqAddUserData = await _apiRequest.AddNewUser(newUser);

		if (!reqAddUserData.status) return;

		if (reqAddUserData.status)
		{
            newUser = new ReqDataUser();

		}
		StateHasChanged();

	}

}
